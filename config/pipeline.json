{
  "dataflows": [
    {
      "name": "motor-ingestion",
      "sources": [
        {
          "name": "policy_inputs",
          "path": "/data/input/events/motor_policy",
          "format": "JSON"
        }
      ],
      "transformations": [
        {
          "name": "validation",
          "type": "validate_fields",
          "params": {
            "input": "policy_inputs",
            "validations": [
              {"field": "policy_number",    "validations": ["notNull", "notEmpty"]},
              {"field": "plate_number",     "validations": ["notEmpty", "validPlate"]},
              {"field": "driver_age",       "validations": ["notNull", "positive", "minAge18", "maxAge100"]},
              {"field": "vehicle_make",     "validations": ["notNull", "validMake"]},
              {"field": "vehicle_year",     "validations": ["notNull", "validYear"]},
              {"field": "price",            "validations": ["notNull", "validPrice"]},
              {"field": "coverage_type",    "validations": ["notNull", "validCoverage"]},
              {"field": "variant",          "validations": ["notNull", "validVariant"]},
              {"field": "deductible",       "validations": ["notNull", "validDeductible"]},
              {"field": "policy_start_date","validations": ["notNull", "validDateFormat", "startBeforeEnd"]},
              {"field": "policy_end_date",  "validations": ["notNull", "validDateFormat"]}
            ]
          }
        },
        {
          "name": "add_ingestion_date",
          "type": "add_fields",
          "params": {
            "input": "validation_ok",
            "addFields": [
              {"name": "ingestion_dt", "function": "current_timestamp"}
            ]
          }
        }
      ],
      "sinks": [
        {
          "input": "add_ingestion_date",
          "name": "raw-ok",
          "paths": ["/data/output/events/motor_policy"],
          "format": "JSON",
          "saveMode": "OVERWRITE"
        },
        {
          "input": "validation_ko",
          "name": "raw-ko",
          "paths": ["/data/output/discards/motor_policy"],
          "format": "JSON",
          "saveMode": "OVERWRITE"
        }
      ]
    }
  ]
}
